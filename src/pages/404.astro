---
import Container from "@/components/Container.astro";
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="404 - Page Not Found"
  description="The page you're looking for doesn't exist."
  robots="noindex,nofollow"
>
  <Container>
    <div class="space-y-8 text-center py-16">
      <div class="space-y-4">
        <h1 class="text-8xl sm:text-9xl font-heading font-bold">
          404
        </h1>
        <h2 class="text-2xl sm:text-3xl font-medium text-zinc-200">
          Page Not Found
        </h2>
      </div>

      <div class="space-y-4 max-w-lg mx-auto">
        <p class="text-lg text-zinc-400 leading-relaxed">
          Oops! The page you're looking for seems to have wandered off into the
          digital void.
        </p>
        <p class="text-zinc-500 text-sm">
          Don't worry though, even the best explorers sometimes take a wrong
          turn.
        </p>
      </div>

      <div
        class="flex flex-col sm:flex-row gap-3 justify-center items-center pt-8"
      >
        <a
          href="/"
          class="flex items-center gap-2 px-5 py-2.5 rounded-surface bg-gradient-to-br from-zinc-800/80 to-zinc-900/80 border border-zinc-700/50 hover:border-zinc-600/60 transition-all text-sm font-medium text-zinc-200 hover:text-yellow-500"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="1em"
            height="1em"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path fill="currentColor" d="M10 20v-6h4v6h5v-8h3L12 3L2 12h3v8z"
            ></path>
          </svg>
          <span>Go Home</span>
        </a>

        <a
          href="/blog"
          class="flex items-center gap-2 px-5 py-2.5 rounded-surface bg-gradient-to-br from-zinc-800/80 to-zinc-900/80 border border-zinc-700/50 hover:border-zinc-600/60 transition-all text-sm font-medium text-zinc-200 hover:text-yellow-500"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="1em"
            height="1em"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill="currentColor"
              d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6M6 20V4h7v5h5v11H6Z"
            ></path>
          </svg>
          <span>Read Blog</span>
        </a>
      </div>

      <div class="pt-12 border-t border-zinc-800">
        <p class="text-xs text-zinc-600 italic font-mono">
          Fun fact: The HTTP 404 error was named after room 404 at CERN where
          the World Wide Web was invented!
        </p>
      </div>
    </div>
  </Container>
</Layout>
