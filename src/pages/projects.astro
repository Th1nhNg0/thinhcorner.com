---
import Container from "@/components/Container.astro";
import { AUTHOR_NAME } from "@/consts";
import Layout from "@/layouts/Layout.astro";

const projects = [
  {
    name: "Vietnamese Legal Documents",
    repo: "th1nhng0/vietnamese-legal-documents",
    url: "https://huggingface.co/datasets/th1nhng0/vietnamese-legal-documents",
    description:
      "A dataset of Vietnamese legal documents collected from thuvienphapluat.vn. Includes laws, decrees, circulars, and other normative documents for NLP research and legal AI applications.",
    tags: ["Dataset", "Vietnamese", "NLP", "Legal", "Hugging Face"],
    year: "2026",
    linkLabel: "View on Hugging Face",
    linkIcon: "huggingface",
  },
  {
    name: "Cars in Loop",
    repo: "GMTK2025",
    url: "https://github.com/Th1nhNg0/GMTK2025",
    description:
      "A grid-based puzzle game made for GMTK Game Jam 2025. Players place track pieces to guide cars through complete loops, visiting checkpoints without crashing.",
    tags: ["TypeScript", "React", "Vite", "Game Jam", "Puzzle"],
    year: "2025",
  },
  {
    name: "Railbound CP Solver",
    repo: "railbound_cp",
    url: "https://github.com/Th1nhNg0/railbound_cp",
    description:
      "A constraint programming solver for the Railbound puzzle game using MiniZinc and OR-Tools. Models track placement, train movement, switches, and gates as a constraint satisfaction problem.",
    tags: ["MiniZinc", "Python", "Constraint Programming", "Puzzle Solver"],
    year: "2025",
  },
];
---

<Layout
  title="Projects — Thinh's Corner"
  description="A showcase of my side projects and experiments."
  lang="en"
  locale="en_US"
  structuredData={{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Projects",
    description: "A showcase of my side projects and experiments.",
    url: new URL("/projects", Astro.site).toString(),
    author: {
      "@type": "Person",
      name: AUTHOR_NAME,
      url: new URL("/", Astro.site).toString(),
    },
  }}
>
  <Container>
    <div class="space-y-10 pb-24">
      <section>
        <h1 class="text-4xl tracking-tight font-bold sm:text-6xl font-heading mb-4">
          Projects
        </h1>
        <p class="text-zinc-400 leading-relaxed max-w-2xl">
          A collection of things I've built — games, tools, and experiments.
        </p>
      </section>

      <ul class="space-y-4" role="list">
        {
          projects.map((project) => (
            <li class="bg-gradient-to-br from-zinc-800/60 to-zinc-900/60 backdrop-blur-sm rounded-surface border border-zinc-700/40 p-5 hover:border-zinc-600/60 hover:from-zinc-800/80 transition-all space-y-4">
              <div class="flex items-start justify-between gap-4">
                <div class="min-w-0">
                  <a
                    href={project.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-lg font-semibold text-zinc-100 hover:text-yellow-500 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-yellow-500 focus-visible:rounded"
                  >
                    {project.name}
                    <span class="sr-only">(opens in new tab)</span>
                  </a>
                  <p class="text-xs text-zinc-500 mt-0.5 font-mono">
                    {project.repo}
                  </p>
                </div>
                <span class="text-xs font-mono text-zinc-400 bg-zinc-800/80 px-2 py-0.5 rounded-full shrink-0">
                  {project.year}
                </span>
              </div>
              <p class="text-sm text-zinc-400 leading-relaxed">
                {project.description}
              </p>
              <div class="flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <span class="text-[11px] font-mono px-2 py-0.5 rounded-full bg-zinc-800/80 text-zinc-500 border border-zinc-700/50">
                    {tag}
                  </span>
                ))}
              </div>
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-xs text-zinc-500 hover:text-yellow-500 transition-colors font-mono"
                aria-hidden="true"
                tabindex="-1"
              >
                {project.linkIcon === "huggingface" ? (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 95 88"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M47.2 2C22.3 2 2 22.3 2 47.2S22.3 92.4 47.2 92.4 92.4 72.1 92.4 47.2 72.1 2 47.2 2zm-.1 12.8c2 0 3.7 1.7 3.7 3.7s-1.7 3.7-3.7 3.7-3.7-1.7-3.7-3.7 1.7-3.7 3.7-3.7zm-14 0c2 0 3.7 1.7 3.7 3.7s-1.7 3.7-3.7 3.7S29.4 20.5 29.4 18.5s1.6-3.7 3.7-3.7zM47 27.5c12.1 0 21.9 9.8 21.9 21.9 0 8.8-5.2 16.4-12.8 20-1.4-1.6-3.4-2.6-5.7-2.6h-6.8c-2.3 0-4.3 1-5.7 2.6C30.3 65.8 25 58.2 25 49.4c.1-12.1 9.9-21.9 22-21.9zm-8.5 10.4c-2.6 0-4.8 2.8-4.8 6.2 0 3.4 2.1 6.2 4.8 6.2 2.6 0 4.8-2.8 4.8-6.2 0-3.4-2.2-6.2-4.8-6.2zm17 0c-2.6 0-4.8 2.8-4.8 6.2 0 3.4 2.1 6.2 4.8 6.2 2.6 0 4.8-2.8 4.8-6.2 0-3.4-2.2-6.2-4.8-6.2zm-8.6 13.6c2.2 0 4 1.2 5 2.9-1.6.4-3.3.7-5 .7s-3.4-.2-5-.7c1-1.8 2.8-2.9 5-2.9zm-6.8 9.1h13.7c1.7 0 3.1 1.4 3.1 3.1v4.5c0 1.7-1.4 3.1-3.1 3.1H40.1c-1.7 0-3.1-1.4-3.1-3.1v-4.5c0-1.7 1.4-3.1 3.1-3.1z"/>
                  </svg>
                ) : (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                  </svg>
                )}
                {project.linkLabel ?? "View on GitHub"}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </Container>
</Layout>
