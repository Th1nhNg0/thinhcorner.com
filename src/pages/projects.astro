---
import Container from "@/components/Container.astro";
import Layout from "@/layouts/Layout.astro";

const projects = [
  {
    name: "Cars in Loop",
    repo: "GMTK2025",
    url: "https://github.com/Th1nhNg0/GMTK2025",
    description:
      "A grid-based puzzle game made for GMTK Game Jam 2025. Players place track pieces to guide cars through complete loops, visiting checkpoints without crashing.",
    tags: ["TypeScript", "React", "Vite", "Game Jam", "Puzzle"],
    year: "2025",
  },
  {
    name: "Railbound CP Solver",
    repo: "railbound_cp",
    url: "https://github.com/Th1nhNg0/railbound_cp",
    description:
      "A constraint programming solver for the Railbound puzzle game using MiniZinc and OR-Tools. Models track placement, train movement, switches, and gates as a constraint satisfaction problem.",
    tags: ["MiniZinc", "Python", "Constraint Programming", "Puzzle Solver"],
    year: "2025",
  },
];
---

<Layout
  title="Projects — Thinh's Corner"
  description="A showcase of my side projects and experiments."
  lang="en"
  locale="en_US"
  structuredData={{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Projects",
    description: "A showcase of my side projects and experiments.",
    url: new URL("/projects", Astro.site).toString(),
    author: {
      "@type": "Person",
      name: "Ngô Phú Thịnh",
      url: new URL("/", Astro.site).toString(),
    },
  }}
>
  <Container>
    <div class="space-y-12 pb-24">
      <div class="space-y-4">
        <h1 class="text-4xl tracking-tight font-bold sm:text-6xl font-heading">
          Projects
        </h1>
        <p class="text-zinc-400 leading-relaxed">
          A collection of things I've built — games, tools, and experiments.
        </p>
      </div>

      <ul class="space-y-10" role="list">
        {
          projects.map((project) => (
            <li class="border border-zinc-800 rounded-lg p-6 space-y-4 hover:border-zinc-700 transition-colors duration-200">
              <div class="flex items-start justify-between gap-4">
                <div class="min-w-0">
                  <a
                    href={project.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xl font-semibold text-zinc-100 hover:text-white transition-colors duration-200"
                  >
                    {project.name}
                  </a>
                  <p class="text-sm text-zinc-500 mt-0.5 font-mono">
                    {project.repo}
                  </p>
                </div>
                <span class="text-sm font-mono text-zinc-500 shrink-0">
                  {project.year}
                </span>
              </div>
              <p class="text-zinc-400 leading-relaxed">
                {project.description}
              </p>
              <div class="flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <span class="text-xs font-mono px-2 py-1 rounded bg-zinc-800 text-zinc-400">
                    {tag}
                  </span>
                ))}
              </div>
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-sm text-zinc-400 hover:text-white transition-colors duration-200"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                </svg>
                View on GitHub
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </Container>
</Layout>
