---
export const prerender = false;
import Container from "@/components/Container.astro";
import Layout from "@/layouts/Layout.astro";
import { get_book } from "@/lib/goodread";
import { format } from "date-fns";
import { GOODREADS_USER_URL } from "@/consts";

const books = await get_book();
const read = books.read;

const readByYear = read.reduce(
  (acc, post) => {
    if (!post.user_read_at) {
      if (!acc["Long time ago"]) {
        acc["Long time ago"] = [];
      }
      acc["Long time ago"].push(post);
      return acc;
    }
    const year = new Date(post.user_read_at).getFullYear();
    if (!acc[year]) {
      acc[year] = [];
    }
    acc[year].push(post);
    return acc;
  },
  {} as Record<string, any[]>,
);

const years = Object.keys(readByYear).sort((a, b) => Number(b) - Number(a));
const now = new Date();
const currentYear = now.getFullYear();

// --- Stats computation ---
const booksThisYear = read.filter(
  (b) => b.user_read_at && new Date(b.user_read_at).getFullYear() === currentYear
).length;

const totalPages = read.reduce((sum, b) => sum + (parseInt(b.num_pages || "0") || 0), 0);

// --- Books per year chart data ---
const numericYears = years.filter((y) => y !== "Long time ago").map(Number).sort((a, b) => a - b);
const yearCounts = numericYears.map((y) => ({ year: y, count: readByYear[y]?.length || 0 }));
const maxYearCount = Math.max(...yearCounts.map((y) => y.count), 1);
const barMaxH = 96; // px
const yearBars = yearCounts.map((item) => ({
  year: item.year,
  count: item.count,
  label: String(item.year).slice(-2),
  barH: Math.max(Math.round((item.count / maxYearCount) * barMaxH), 4),
}));

// --- Books per month chart (this year + all time) ---
const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
const currentMonth = now.getMonth();

const monthCountsThisYear = new Array(12).fill(0);
const monthCountsAllTime = new Array(12).fill(0);
read.forEach((b) => {
  if (b.user_read_at) {
    const d = new Date(b.user_read_at);
    monthCountsAllTime[d.getMonth()]++;
    if (d.getFullYear() === currentYear) {
      monthCountsThisYear[d.getMonth()]++;
    }
  }
});

const maxMonthThisYear = Math.max(...monthCountsThisYear, 1);
const maxMonthAllTime = Math.max(...monthCountsAllTime, 1);

const monthBarsThisYear = monthCountsThisYear.map((count, i) => ({
  count,
  label: monthNames[i],
  barH: count > 0 ? Math.max(Math.round((count / maxMonthThisYear) * barMaxH), 4) : 0,
  isEmpty: count === 0,
  isFuture: i > currentMonth,
}));

const monthBarsAllTime = monthCountsAllTime.map((count, i) => ({
  count,
  label: monthNames[i],
  barH: count > 0 ? Math.max(Math.round((count / maxMonthAllTime) * barMaxH), 4) : 0,
  isEmpty: count === 0,
  isFuture: false,
}));
---

<Layout
  title="Reading"
  description="A list of books I've read and recommend."
  structuredData={{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Reading",
    description: "A list of books I've read and recommend.",
    url: new URL("/reading", Astro.site).toString(),
  }}
>
  <Container>
    <section class="prose max-w-none prose-invert prose-a:text-yellow-500">
      <h1
        class="text-4xl font-bold not-prose tracking-tight sm:text-6xl inline-block font-heading"
      >
        My bookshelf
      </h1>
      <p>
        This is a collection of what I've read over the past years,
        automatically generated from my
        <a href={GOODREADS_USER_URL}>Goodreads profile.</a>
      </p>
      <p>
        I'm currently reading: {
          books.current_reads.map((book, index) => (
            <>
              <a href={book.url}>{book.title}</a> by {book.author}
              {index === books.current_reads.length - 2
                ? " and "
                : index < books.current_reads.length - 2
                  ? ", "
                  : ""}
            </>
          ))
        }
      </p>
      <p class="leading-relaxed italic">
        "Books gives a soul to the universe, wings to the mind, flight to the
        imagination, and life to everything." — Plato
      </p>
    </section>

    {/* --- Stats bar --- */}
    <section class="mt-8 grid grid-cols-2 gap-3">
      <div class="bg-gradient-to-br from-zinc-800/80 to-zinc-900/80 backdrop-blur-sm rounded-surface border border-zinc-700/50 p-4 text-center">
        <div class="text-2xl font-bold font-heading text-zinc-100">{booksThisYear}</div>
        <div class="text-xs text-zinc-400 mt-1">books in {currentYear}</div>
      </div>
      <div class="bg-gradient-to-br from-zinc-800/80 to-zinc-900/80 backdrop-blur-sm rounded-surface border border-zinc-700/50 p-4 text-center">
        <div class="text-2xl font-bold font-heading text-zinc-100">{totalPages.toLocaleString()}</div>
        <div class="text-xs text-zinc-400 mt-1">pages total</div>
      </div>
    </section>

    {/* --- Charts side by side --- */}
    <section class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
      {/* Books per year */}
      {yearBars.length > 1 && (
        <div class="bg-gradient-to-br from-zinc-800/80 to-zinc-900/80 backdrop-blur-sm rounded-surface border border-zinc-700/50 p-5">
          <h2 class="text-sm font-medium text-zinc-400 mb-4">Books per year</h2>
          <div class="flex items-end gap-1" style="height: 120px">
            {yearBars.map((bar) => (
              <div class="flex-1 flex flex-col items-center gap-1 h-full justify-end">
                <span class="text-[10px] text-zinc-400">{bar.count}</span>
                <div
                  class="w-full rounded-sm bg-yellow-500/80"
                  style={`height: ${bar.barH}px`}
                />
                <span class="text-[9px] text-zinc-500">{bar.label}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Books per month with toggle */}
      <div class="bg-gradient-to-br from-zinc-800/80 to-zinc-900/80 backdrop-blur-sm rounded-surface border border-zinc-700/50 p-5">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-medium text-zinc-400">By month</h2>
          <div class="flex gap-1 text-[11px]">
            <button class="month-toggle active px-2 py-0.5 rounded-full bg-zinc-700 text-zinc-200 border border-zinc-600 cursor-pointer transition-colors" data-mode="thisyear">
              {currentYear}
            </button>
            <button class="month-toggle px-2 py-0.5 rounded-full text-zinc-500 border border-zinc-700/50 cursor-pointer transition-colors hover:text-zinc-300" data-mode="alltime">
              All time
            </button>
          </div>
        </div>
        {/* This year bars */}
        <div id="month-thisyear" class="flex items-end gap-1" style="height: 120px">
          {monthBarsThisYear.map((bar) => (
            <div class="flex-1 flex flex-col items-center gap-1 h-full justify-end">
              {bar.count > 0 && <span class="text-[10px] text-zinc-400">{bar.count}</span>}
              <div
                class={`w-full rounded-sm ${bar.isEmpty ? (bar.isFuture ? "bg-zinc-800/40" : "bg-zinc-700/40") : "bg-yellow-500/80"}`}
                style={`height: ${bar.isEmpty ? 3 : bar.barH}px`}
              />
              <span class="text-[9px] text-zinc-500">{bar.label}</span>
            </div>
          ))}
        </div>
        {/* All time bars */}
        <div id="month-alltime" class="flex items-end gap-1 hidden" style="height: 120px">
          {monthBarsAllTime.map((bar) => (
            <div class="flex-1 flex flex-col items-center gap-1 h-full justify-end">
              {bar.count > 0 && <span class="text-[10px] text-zinc-400">{bar.count}</span>}
              <div
                class={`w-full rounded-sm ${bar.isEmpty ? "bg-zinc-700/40" : "bg-yellow-500/80"}`}
                style={`height: ${bar.isEmpty ? 3 : bar.barH}px`}
              />
              <span class="text-[9px] text-zinc-500">{bar.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="mt-8" id="bookList">
      {
        years.map((year) => (
          <div class="mb-10" data-year={year}>
            <h2 class="text-accent mb-6 text-2xl text-zinc-200 font-mono font-bold">
              {year}
              <span class="text-sm font-normal text-zinc-500 ml-2">
                ({readByYear[year].length} {readByYear[year].length === 1 ? "book" : "books"})
              </span>
            </h2>
            <ul class="grid grid-cols-1 md:grid-cols-2 gap-4" role="list">
              {readByYear[year].map((book) => (
                <li class="flex gap-4 bg-gradient-to-br from-zinc-800/80 to-zinc-900/80 backdrop-blur-sm rounded-surface border border-zinc-700/50 p-4 transition-all duration-200 hover:border-zinc-600/80">
                  {book.cover && (
                    <img
                      src={book.cover}
                      alt={`Cover of ${book.title}`}
                      class="w-20 h-[7.5rem] object-cover rounded-md shadow-md flex-shrink-0"
                    />
                  )}
                  <div class="flex flex-col flex-1 min-w-0">
                    <a
                      href={book.url}
                      class="text-zinc-100 font-medium hover:text-yellow-500 transition-colors line-clamp-2"
                    >
                      {book.title}
                    </a>
                    <p class="text-sm text-zinc-400 mt-0.5">by {book.author}</p>
                    <div class="flex items-center gap-3 mt-auto pt-2 text-sm text-zinc-500">
                      {book.rating > 0 && (
                        <span class="text-yellow-500 tracking-wider" title={`${book.rating}/5`}>
                          {"★".repeat(book.rating)}
                        </span>
                      )}
                      {book.num_pages && (
                        <span>{book.num_pages}p</span>
                      )}
                      {book.user_read_at && (
                        <span>
                          {format(new Date(book.user_read_at), "MMM yyyy")}
                        </span>
                      )}
                    </div>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </section>

    <p class="text-sm text-zinc-500 mt-4 text-right">
      {read.length} books total &middot; Last updated: <time
        datetime={now.toISOString()}
        title={now.toISOString()}
      >
        {format(now, "MMM d, yyyy")}
      </time>
    </p>
  </Container>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const toggles = document.querySelectorAll<HTMLButtonElement>(".month-toggle");
    const thisYearChart = document.getElementById("month-thisyear");
    const allTimeChart = document.getElementById("month-alltime");
    if (!thisYearChart || !allTimeChart) return;

    toggles.forEach((btn) => {
      btn.addEventListener("click", () => {
        toggles.forEach((b) => {
          b.classList.remove("active", "bg-zinc-700", "text-zinc-200", "border-zinc-600");
          b.classList.add("text-zinc-500", "border-zinc-700/50");
        });
        btn.classList.add("active", "bg-zinc-700", "text-zinc-200", "border-zinc-600");
        btn.classList.remove("text-zinc-500", "border-zinc-700/50");

        if (btn.dataset.mode === "thisyear") {
          thisYearChart.classList.remove("hidden");
          allTimeChart.classList.add("hidden");
        } else {
          thisYearChart.classList.add("hidden");
          allTimeChart.classList.remove("hidden");
        }
      });
    });
  });
</script>
