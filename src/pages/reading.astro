---
export const prerender = false;
import Container from "@/components/Container.astro";
import Layout from "@/layouts/Layout.astro";
import { get_book } from "@/lib/goodread";
import { format } from "date-fns";
import { GOODREADS_USER_URL } from "@/consts";

const books = await get_book();
const read = books.read;

const readByYear = read.reduce(
  (acc, post) => {
    if (!post.user_read_at) {
      if (!acc["Long time ago"]) {
        acc["Long time ago"] = [];
      }
      acc["Long time ago"].push(post);
      return acc;
    }
    const year = new Date(post.user_read_at).getFullYear();
    if (!acc[year]) {
      acc[year] = [];
    }
    acc[year].push(post);
    return acc;
  },
  {} as Record<string, any[]>,
);

const years = Object.keys(readByYear).sort((a, b) => Number(b) - Number(a));
const now = new Date();
---

<Layout
  title="Reading"
  description="A list of books I've read and recommend."
  structuredData={{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Reading",
    description: "A list of books I've read and recommend.",
    url: new URL("/reading", Astro.site).toString(),
  }}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <section class="prose max-w-none prose-invert prose-a:text-yellow-500">
      <h1
        class="text-4xl font-bold not-prose tracking-tight sm:text-6xl inline-block font-heading"
      >
        My bookshelf
      </h1>
      <p>
        A collection of what I’ve read over the years, from my
        <a href={GOODREADS_USER_URL}>Goodreads</a>.
        <span class="text-zinc-400">{read.length} books and counting.</span>
      </p>
      {books.current_reads.length > 0 && (
        <p>
          Currently reading: {
            books.current_reads.map((book, index) => (
              <>
                <a href={book.url}>{book.title}</a>
                {index === books.current_reads.length - 2
                  ? " and "
                  : index < books.current_reads.length - 2
                    ? ", "
                    : ""}
              </>
            ))
          }
        </p>
      )}
      <p class="leading-relaxed italic text-zinc-500 border-l-2 border-zinc-700 pl-4">
        "Books give a soul to the universe, wings to the mind, flight to the
        imagination, and life to everything." — Plato
      </p>
      <p class="text-xs text-zinc-600 mt-4 text-right not-prose">
        Updated {format(now, "MMM d, yyyy")}
      </p>
    </section>
    <section class="mt-10" id="blogPosts">
      {
        years.map((year) => (
          <div class="mb-12" data-year={year}>
            <div class="flex items-baseline gap-3 mb-6">
              <h2 class="text-2xl text-zinc-200 font-mono font-bold">
                {year}
              </h2>
              <span class="text-sm text-zinc-600 font-mono">
                {readByYear[year].length} {readByYear[year].length === 1 ? "book" : "books"}
              </span>
            </div>
            <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 sm:gap-5" role="list">
              {readByYear[year].map((book) => (
                <li class="group flex flex-col">
                  <a href={book.url} class="block relative aspect-[2/3] mb-2.5 overflow-hidden rounded-lg bg-zinc-800 border border-zinc-800 hover:border-zinc-600 transition-all duration-200">
                    {book.cover ? (
                      <img
                        src={book.cover}
                        alt={`Cover of ${book.title}`}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        loading="lazy"
                      />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center p-3 text-center">
                        <span class="text-xs text-zinc-500 line-clamp-4">{book.title}</span>
                      </div>
                    )}
                  </a>
                  <a
                    href={book.url}
                    class="text-sm text-zinc-300 font-medium leading-snug hover:text-white transition-colors line-clamp-2"
                  >
                    {book.title}
                  </a>
                  <p class="text-xs text-zinc-600 mt-0.5 line-clamp-1">{book.author}</p>
                  {book.rating > 0 && (
                    <div class="flex items-center gap-1 mt-1">
                      <span class="text-yellow-500/80 text-[10px] tracking-wider">
                        {"★".repeat(Math.round(book.rating))}
                      </span>
                    </div>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </section>
  </div>
</Layout>
