---
export const prerender = false;
import Container from "@/components/Container.astro";
import Layout from "@/layouts/Layout.astro";
import { getRecentlyPlayed, getTopArtists, getTopTracks } from "@/lib/spotify";
import { SOCIAL_MEDIA } from "@/consts";
import { format, formatDistanceToNow } from "date-fns";
import { env } from "cloudflare:workers";

const topTracks = await getTopTracks(env, env.CACHE);
const recentlyPlayed = await getRecentlyPlayed(env, env.CACHE);
const topArtists = await getTopArtists(env, env.CACHE);
const now = new Date();
---

<Layout
  title="Music"
  description="A list of music I've listened to and recommend."
  structuredData={{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Music",
    description: "A list of music I've listened to and recommend.",
    url: new URL("/music", Astro.site).toString(),
  }}
>
  <Container>
    <section class="mb-6">
      <h1
        class="text-4xl font-bold tracking-tight sm:text-6xl font-heading mb-4"
      >
        My music library
      </h1>
      <p class="text-zinc-400 leading-relaxed max-w-2xl">
        A collection of what I've listened to over the past 4 weeks,
        automatically generated from my
        <a href={SOCIAL_MEDIA.spotify} class="text-yellow-500 hover:text-yellow-400 transition-colors"
          >Spotify profile</a
        >.
      </p>
    </section>

    <p class="text-zinc-500 italic text-sm mb-8 border-l-2 border-zinc-700 pl-4">
      "Music is that voice that tells us that the human race is greater than
      it knows." — Napoleon Bonaparte
    </p>

    <section class="mb-8">
      <h2 class="text-sm font-mono text-zinc-500 uppercase tracking-wider mb-4">Recently Played</h2>
      <div class="space-y-2">
        {
          recentlyPlayed.map((track) => (
            <a
              href={track.songUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-3 p-2 bg-gradient-to-br from-zinc-800/80 to-zinc-900/80 backdrop-blur-sm rounded-surface border border-zinc-700/50 transition-all"
            >
              <div class="relative w-12 h-12 sm:w-16 sm:h-16">
                <img
                  src={track.imageUrl}
                  alt={track.title}
                  width="64"
                  height="64"
                  loading="lazy"
                  decoding="async"
                  class="rounded-md object-cover w-full h-full"
                />
                <div class="absolute inset-0 bg-black/20 group-hover:bg-black/40 rounded-md flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity" aria-hidden="true">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="w-6 h-6 text-white"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M4.5 5.653c0-1.426 1.529-2.33 2.779-1.643l11.54 6.348c1.295.712 1.295 2.573 0 3.285L7.28 19.991c-1.25.687-2.779-.217-2.779-1.643V5.653z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </div>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="font-medium text-sm sm:text-base group-hover:text-white transition-colors line-clamp-1">
                  {track.title}
                </h3>
                <p class="text-zinc-400 text-xs sm:text-sm line-clamp-1">
                  {track.artist.map((a) => a.name).join(", ")}
                </p>
                <p class="text-zinc-500 text-xs mt-0.5">
                  Played{" "}
                  {formatDistanceToNow(new Date(track.played_at), {
                    addSuffix: true,
                  })}
                </p>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <section class="mb-8">
      <h2 class="text-sm font-mono text-zinc-500 uppercase tracking-wider mb-4">Top Tracks</h2>
      <div class="grid grid-cols-3 md:grid-cols-5 gap-3">
        {
          topTracks.map((track) => (
            <a
              href={track.songUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="group p-2 bg-gradient-to-br from-zinc-800/80 to-zinc-900/80 backdrop-blur-sm rounded-surface border border-zinc-700/50 transition-all last:hidden sm:last:block"
            >
              <div class="relative aspect-square mb-2">
                <img
                  src={track.imageUrl}
                  alt={track.title}
                  width="300"
                  height="300"
                  loading="lazy"
                  decoding="async"
                  class="rounded-md object-cover w-full h-full"
                />
                <div class="absolute inset-0 bg-black/40 rounded-md opacity-0 group-hover:opacity-100 transition-all flex items-center justify-center" aria-hidden="true">
                  <div class="bg-white/20 p-2 rounded-full">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="w-6 h-6"
                      aria-hidden="true"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M4.5 5.653c0-1.426 1.529-2.33 2.779-1.643l11.54 6.348c1.295.712 1.295 2.573 0 3.285L7.28 19.991c-1.25.687-2.779-.217-2.779-1.643V5.653z"
                        clip-rule="evenodd"
                      />
                    </svg>
                  </div>
                </div>
              </div>
              <h3 class="font-medium text-xs sm:text-sm group-hover:text-white transition-colors line-clamp-1">
                {track.title}
              </h3>
              <p class="text-zinc-400 text-xs line-clamp-1">
                {track.artist.map((a) => a.name).join(", ")}
              </p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="mb-8">
      <h2 class="text-sm font-mono text-zinc-500 uppercase tracking-wider mb-4">Top Artists</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {
          topArtists.map((artist) => (
            <a
              href={artist.external_urls.spotify}
              target="_blank"
              rel="noopener noreferrer"
              class="group block relative overflow-hidden rounded-xl aspect-[4/3]"
            >
              <img
                src={artist.images[0].url}
                alt={artist.name}
                width="640"
                height="480"
                loading="lazy"
                decoding="async"
                class="absolute inset-0 object-cover w-full h-full transition-transform duration-500 group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent opacity-80 group-hover:opacity-100 transition-opacity" />
              <div class="absolute inset-0 p-4 flex flex-col justify-end">
                <h3 class="text-xl font-bold text-white mb-1 drop-shadow-sm">
                  {artist.name}
                </h3>
                <div class="flex items-center gap-3 text-xs text-zinc-300">
                  <div class="flex items-center gap-1">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="w-4 h-4"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M8 9a3 3 0 100-6 3 3 0 000 6zM8 11a6 6 0 016 6H2a6 6 0 016-6z" />
                    </svg>
                    <span>{artist.followers.total.toLocaleString()} followers</span>
                  </div>
                  <div class="flex items-center gap-1">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="w-4 h-4"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                    <span>{artist.popularity}% popularity</span>
                  </div>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <p class="text-xs text-zinc-600 font-mono text-right mt-4 mb-8">
      Last updated: <time id="last-updated" datetime={now.toISOString()}>{format(now, "MMM d, yyyy 'at' h:mm a")}</time>
    </p>
  </Container>
</Layout>

<script>
  const el = document.getElementById("last-updated");
  if (el) {
    const d = new Date(el.getAttribute("datetime")!);
    el.textContent = d.toLocaleString(undefined, {
      month: "short",
      day: "numeric",
      year: "numeric",
      hour: "numeric",
      minute: "2-digit",
    });
  }
</script>
