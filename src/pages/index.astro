---
import Container from "@/components/Container.astro";
import { AUTHOR_EMAIL, AUTHOR_NAME, SITE, SOCIAL_MEDIA } from "@/consts";
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { format } from "date-fns";

const blog = (await getCollection("blog"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<Layout
  title={SITE.title}
  description={SITE.description}
  lang="en"
  locale="en_US"
  structuredData={[
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: SITE.title,
      url: new URL("/", Astro.site).toString(),
      description: SITE.description,
      inLanguage: "en",
    },
    {
      "@context": "https://schema.org",
      "@type": "Person",
      name: AUTHOR_NAME,
      url: new URL("/", Astro.site).toString(),
      jobTitle: "Curious Mind",
      address: {
        "@type": "PostalAddress",
        addressLocality: "Ho Chi Minh City",
        addressCountry: "VN",
      },
      sameAs: [
        SOCIAL_MEDIA.github,
        SOCIAL_MEDIA.facebook,
        SOCIAL_MEDIA.spotify,
        SOCIAL_MEDIA.linkedin,
      ].filter(Boolean),
    },
  ]}
>
  <Container>
    <div class="space-y-8">
      <h1
        class="text-4xl tracking-tight font-bold sm:text-6xl inline-block font-heading"
      >
        {AUTHOR_NAME}
      </h1>
      <div class="space-y-4 text-zinc-400">
        <p class="leading-relaxed">
          Hey there! I'm {AUTHOR_NAME}, based in Ho Chi Minh City, Vietnam.
          I'm the kind of person who falls down rabbit holes — one week it's
          a puzzle game I can't put down, the next it's a book that
          changes how I see things, and sometimes it's a weird idea I just
          have to build.
        </p>
        <p class="leading-relaxed">
          This little corner is where I collect the things I find along the
          way — what I'm <a href="/reading" class="text-yellow-500 hover:text-yellow-400 transition-colors">reading</a>,
          what I'm <a href="/music" class="text-yellow-500 hover:text-yellow-400 transition-colors">listening to</a>,
          and whatever I'm <a href="/projects" class="text-yellow-500 hover:text-yellow-400 transition-colors">tinkering with</a>.
          Nothing too serious, just a curious mind trying to make sense of the world.
        </p>
      </div>
      <section class="mb-16">
        <div class="flex items-center gap-3 mb-5">
          <h2 class="text-xl text-zinc-200 font-mono font-bold">
            <a href="/blog/">Posts</a>
          </h2>
          <div class="flex-1 h-px bg-zinc-800"></div>
        </div>
        <ul class="space-y-2" role="list">
          {
            blog.map((post) => (
              <li class="group flex items-baseline gap-4 py-2 px-3 -mx-3 rounded-lg hover:bg-zinc-800/40 transition-colors">
                <time
                  datetime={post.data.date.toISOString()}
                  title={post.data.date.toISOString()}
                  class="shrink-0 text-xs font-mono text-zinc-500 min-w-[5.5rem]"
                >
                  {format(new Date(post.data.date), "dd MMM yyyy")}
                </time>
                <div class="text-zinc-300 group-hover:text-zinc-100 transition-colors text-sm">
                  {post.data.draft && (
                    <span class="text-yellow-500 font-bold mr-2 text-xs">
                      [Draft]
                    </span>
                  )}
                  <a
                    data-astro-prefetch=""
                    href={`/blog/${post.id}`}
                    class="hover:text-yellow-500 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-yellow-500 focus-visible:rounded"
                  >
                    {post.data.title}
                  </a>
                </div>
              </li>
            ))
          }
        </ul>
      </section>
      <footer
        class="mt-20 border-t border-zinc-800 pt-8 pb-12 text-sm text-zinc-400 text-right"
      >
        <div
          class="flex flex-col gap-3 text-base text-zinc-200 sm:flex-row sm:items-center sm:justify-end sm:gap-6"
        >
          <a
            href={`mailto:${AUTHOR_EMAIL}`}
            class="transition-colors duration-200 hover:text-yellow-500"
          >
            {AUTHOR_EMAIL}
          </a>
          {
            SOCIAL_MEDIA.github && (
              <a
                href={SOCIAL_MEDIA.github}
                target="_blank"
                class="transition-colors duration-200 hover:text-yellow-500"
                aria-label="GitHub Profile (opens in new tab)"
              >
                GitHub
              </a>
            )
          }
          {
            SOCIAL_MEDIA.linkedin && (
              <a
                href={SOCIAL_MEDIA.linkedin}
                target="_blank"
                class="transition-colors duration-200 hover:text-yellow-500"
                aria-label="LinkedIn Profile (opens in new tab)"
              >
                LinkedIn
              </a>
            )
          }
        </div>
      </footer>
    </div>
  </Container>
</Layout>
